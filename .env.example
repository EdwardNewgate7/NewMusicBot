# ═══════════════════════════════════════════════════════
#         🎵 HARMONY MUSIC v3.0 - YAPILANDIRMA
# ═══════════════════════════════════════════════════════

# Telegram Bot Token (BotFather'dan alınır)
BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# Bot Sahibi / Geliştirici ID'leri (virgülle ayırın)
OWNER_IDS=123456789,987654321

# Bot Bilgileri
BOT_USERNAME=HarmonyMusicBot
BOT_NAME=Harmony Music

# Geliştirici Bilgileri
DEV_USERNAME=@gelistirici1
DEV2_USERNAME=@gelistirici2

# Asistan Bot Bilgileri (varsayılan profil referansı)
ASSISTANT_BOT_USERNAME=@HarmonyAsistanBot

# ═══════════════════════════════════════════════════════
#             👤 ASİSTAN (USERBOT) AYARLARI
# ═══════════════════════════════════════════════════════
# Asistan hesabını aktif etmek için true yapın
ASSISTANT_ENABLED=false

# my.telegram.org adresinden alacağınız bilgiler
ASSISTANT_API_ID=
ASSISTANT_API_HASH=

# Giriş yapacak hesap (opsiyonel, string_session da kullanılabilir)
ASSISTANT_PHONE_NUMBER=
ASSISTANT_STRING_SESSION=

# ── Veritabanı ─────────────────────────────────────────
# SQLite veritabanı dosya yolu
DATABASE_PATH=data/harmony_music.db

# ═══════════════════════════════════════════════════════
#              🍪 COOKIE.TXT AYARLARI
# ═══════════════════════════════════════════════════════
# YouTube'un yaş kısıtlamalı, bölge kısıtlamalı veya
# giriş gerektiren videolara erişim için cookie.txt.
#
# 📋 Cookie.txt Nasıl Alınır:
# 1. Chrome/Firefox'a "Get cookies.txt LOCALLY" eklentisini kurun
# 2. YouTube.com'a giriş yapın
# 3. Eklenti ile cookie'leri dışa aktarın
# 4. Dosyayı proje dizinine "cookie.txt" adıyla kaydedin
#
# Cookie dosyasının yolu (varsayılan: proje_dizini/cookie.txt)
COOKIE_FILE=cookie.txt

# Cookie kullanımını etkinleştir/devre dışı bırak
# true = aktif, false = devre dışı
COOKIE_ENABLED=true

# ═══════════════════════════════════════════════════════
#              🎚 GELİŞMİŞ SES AYARLARI
# ═══════════════════════════════════════════════════════
# Ses kalitesi (kbps): 64, 128, 192, 256, 320
AUDIO_QUALITY=320

# Ses formatı: mp3, m4a, opus, flac
AUDIO_FORMAT=mp3

# Video kalitesi: 360, 480, 720, 1080
VIDEO_QUALITY=720

# FFmpeg özel yolu (boş = sistem PATH'inden kullanılır)
FFMPEG_PATH=

# ═══════════════════════════════════════════════════════
#              🔍 MÜZİK ARAMA AYARLARI
# ═══════════════════════════════════════════════════════
# Varsayılan arama sonuç sayısı
DEFAULT_SEARCH_RESULTS=5

# Maksimum arama sonuç sayısı
MAX_SEARCH_RESULTS=10

# ── Müzik Ayarları ─────────────────────────────────────
# Maksimum şarkı süresi (saniye) - varsayılan 10 dakika
MAX_SONG_DURATION=600

# İndirilen dosyaların saklanacağı dizin
DOWNLOAD_PATH=downloads

# İndirilen dosyaları belirli süre sonra sil (saniye)
# 0 = silme, varsayılan 3600 (1 saat)
AUTO_CLEANUP_SECONDS=3600

# ── Dosya Boyutu Limitleri ─────────────────────────────
# Maksimum ses dosyası boyutu (byte) - 50MB
MAX_AUDIO_FILE_SIZE=52428800

# Maksimum video dosyası boyutu (byte) - 50MB
MAX_VIDEO_FILE_SIZE=52428800

# ── Limitler ───────────────────────────────────────────
# Kullanıcı başına maksimum playlist şarkı sayısı
MAX_PLAYLIST_SIZE=50

# Kuyruk başına maksimum şarkı sayısı
MAX_QUEUE_SIZE=25

# Throttle - Komut başına bekleme süresi (saniye)
THROTTLE_RATE=2

# ═══════════════════════════════════════════════════════
#              ⚡ yt-dlp GELİŞMİŞ AYARLARI
# ═══════════════════════════════════════════════════════
# Coğrafi kısıtlama bypass
YTDLP_GEO_BYPASS=true

# Bağlantı zaman aşımı (saniye)
YTDLP_SOCKET_TIMEOUT=30

# Yeniden deneme sayısı
YTDLP_RETRIES=3

# ═══════════════════════════════════════════════════════
#              📝 ŞARKI SÖZLERİ
# ═══════════════════════════════════════════════════════
# Genius API Token (opsiyonel - daha iyi sonuçlar için)
# https://genius.com/api-clients adresinden alınabilir
GENIUS_API_TOKEN=

# ── Radyo ──────────────────────────────────────────────
DEFAULT_RADIO_URL=https://listen.powerapp.com.tr/powerfm/mpeg/icecast.audio
